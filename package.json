{
  "name": "command-launcher",
  "version": "0.1.0",
  "private": true,
  "description": "Command Launcher — premium Minecraft launcher UI (Next.js + Electron)",
  "main": "electron/main.js",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "electron:dev": "concurrently -k \"npm:dev\" \"wait-on http://localhost:3000 && electron .\"",
    "electron:build": "next build && electron-builder"
  },
  "dependencies": {
    "next": "15.5.20",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "framer-motion": "11.11.17",
    "lucide-react": "0.454.0",
    "clsx": "2.1.1",
    "tailwind-merge": "2.5.4"
  },
  "devDependencies": {
    "typescript": "5.6.3",
    "@types/react": "18.3.12",
    "@types/react-dom": "18.3.1",
    "@types/node": "22.9.0",
    "tailwindcss": "3.4.14",
    "postcss": "8.4.49",
    "autoprefixer": "10.4.20",
    "electron": "33.2.0",
    "electron-builder": "25.1.8",
    "concurrently": "9.0.1",
    "wait-on": "8.0.1"
  },
  "build": {
    "appId": "com.pgc.commandlauncher",
    "productName": "Command Launcher",
    "files": [
      "out/**/*",
      "electron/**/*"
    ],
    "directories": {
      "output": "dist"
    },
    "win": { "target": "nsis" },
    "linux": { "target": "AppImage" }
  }
}
