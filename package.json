{
  "name": "command-launcher",
  "version": "1.0.0",
  "description": "Command Launcher - a Lunar/Feather-styled Minecraft launcher",
  "private": true,
  "main": "dist-electron/main.js",
  "scripts": {
    "dev": "vite",
    "build:renderer": "vue-tsc --noEmit && vite build",
    "build:electron": "tsc -p electron/tsconfig.json",
    "build": "npm run build:renderer && npm run build:electron",
    "dist": "npm run build && electron-builder",
    "dist:win": "npm run build && electron-builder --win --x64 --ia32",
    "dist:win64": "npm run build && electron-builder --win --x64",
    "dist:win32": "npm run build && electron-builder --win --ia32",
    "dist:mac": "npm run build && electron-builder --mac --x64 --arm64",
    "dist:linux": "npm run build && electron-builder --linux --x64",
    "electron": "electron ."
  },
  "dependencies": {
    "adm-zip": "^0.5.10",
    "pinia": "^2.1.7",
    "vue": "^3.4.21",
    "vue-router": "^4.3.0"
  },
  "devDependencies": {
    "@types/adm-zip": "^0.5.5",
    "@types/node": "^20.12.7",
    "@vitejs/plugin-vue": "^5.0.4",
    "electron": "^30.0.1",
    "electron-builder": "^24.13.3",
    "typescript": "^5.4.5",
    "vite": "^5.2.8",
    "vue-tsc": "^2.0.11"
  },
  "build": {
    "appId": "fun.pgcmc.commandlauncher",
    "productName": "Command Launcher",
    "artifactName": "${productName}-${version}-${os}-${arch}.${ext}",
    "files": [
      "dist/**/*",
      "dist-electron/**/*",
      "package.json"
    ],
    "directories": {
      "output": "release"
    },
    "win": {
      "target": [
        { "target": "nsis", "arch": ["x64", "ia32"] }
      ],
      "icon": "build/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "artifactName": "${productName}-Setup-${version}-${arch}.${ext}"
    },
    "linux": {
      "target": [
        { "target": "AppImage", "arch": ["x64"] }
      ],
      "icon": "build/icon.png",
      "category": "Game"
    },
    "mac": {
      "target": [
        { "target": "dmg", "arch": ["x64", "arm64"] }
      ],
      "icon": "build/icon.icns",
      "identity": null
    }
  }
}
